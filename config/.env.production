# 生产环境配置

# ================================
# 服务器配置
# ================================
# SERVER_HOST=0.0.0.0  # 监听所有网络接口
PORT=3000
WS_PORT=3001
NODE_ENV=production
HTTPS=true
WSS=true

# ================================
# CORS 配置
# ================================
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=https://localhost:5173,https://localhost:3000

# ================================
# 路径配置
# ================================
DATA_DIR=/var/lib/auto-test-agent/data
LOGS_DIR=/var/log/auto-test-agent
TEMP_DIR=/tmp/auto-test-agent
SCREENSHOTS_DIR=/var/lib/auto-test-agent/screenshots
REPORTS_DIR=/var/lib/auto-test-agent/reports
TASKS_DIR=/var/lib/auto-test-agent/tasks

# ================================
# 数据库配置
# ================================
DATABASE_URL=/var/lib/auto-test-agent/tasks.db
DATABASE_POOL_SIZE=20

# ================================
# 日志配置
# ================================
LOG_LEVEL=info
LOG_FILE=/var/log/auto-test-agent/server.log
LOG_MAX_SIZE=52428800  # 50MB
LOG_MAX_FILES=10

# ================================
# 任务执行配置
# ================================
TASK_TIMEOUT=120000  # 2分钟
MAX_RETRIES=3
DEFAULT_HEADLESS=true
SCREENSHOT_ON_FAILURE=true
SLOW_MO=0

# ================================
# Playwright 配置
# ================================
PLAYWRIGHT_BROWSERS_PATH=0
PLAYWRIGHT_CHANNEL=chromium
PLAYWRIGHT_DEVTOOLS=false

# ================================
# 客户端配置
# ================================
CLIENT_HEARTBEAT_INTERVAL=60000  # 1分钟
CLIENT_TIMEOUT=120000  # 2分钟
CLIENT_MAX_RECONNECT=10

# ================================
# API 配置
# ================================
RATE_LIMIT_WINDOW=600000  # 10分钟
RATE_LIMIT_MAX=50

# ================================
# 性能配置
# ================================
ENABLE_PROFILING=false
ENABLE_METRICS=true

# ================================
# 调试配置
# ================================
DEBUG=false
