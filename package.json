{
  "name": "auto-test-agent",
  "version": "0.2.0",
  "private": true,
  "description": "一个桌面客户端的自动化测试工具",
  "scripts": {
    "dev": "pnpm --filter \"./packages/**\" --parallel dev",
    "dev:server": "pnpm --filter @auto-test-agent/server dev",
    "dev:web": "pnpm --filter @auto-test-agent/web-console dev",
    "build": "pnpm --filter \"./packages/**\" build",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf node_modules **/node_modules **/dist",
    "config": "tsx scripts/config.ts",
    "config:init": "tsx scripts/config.ts init",
    "config:validate": "tsx scripts/config.ts validate",
    "config:show": "tsx scripts/config.ts show",
    "config:check": "tsx scripts/config.ts check",
    "download:chromium": "node scripts/download-chromium.js",
    "test": "jest",
    "test:unit": "jest --testPathPattern=\"__tests__\"",
    "test:e2e": "jest --testPathPattern=\"e2e\"",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:performance": "node tests/performance/benchmark.js"
  },
  "keywords": [
    "automation",
    "testing",
    "electron",
    "midscene",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "decompress": "^4.2.1",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.2"
}
