# Midscene 视觉AI模型配置
# 必须配置一个视觉模型才能使用 AI 视觉定位功能
# 支持的模型系列: glm-v, qwen3-vl, qwen3.5, gemini, gpt-5 等
# 详见: https://midscenejs.com/model-common-config

# 模型名称 (必填)
# 智谱: glm-4.6v | glm-5v-turbo
# 通义千问: qwen3-vl-plus | qwen3.5-plus
# Google: gemini-3-flash
MIDSCENE_MODEL_NAME=glm-4.6v

# API Key (必填)
MIDSCENE_MODEL_API_KEY=your_api_key_here

# API Base URL (必填)
# 智谱: https://open.bigmodel.cn/api/paas/v4
# 通义千问: https://dashscope.aliyuncs.com/compatible-mode/v1
# Google: https://generativelanguage.googleapis.com/v1beta/openai/
MIDSCENE_MODEL_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 模型系列 (必填)
# 智谱: glm-v | 通义千问: qwen3-vl | Google: gemini
MIDSCENE_MODEL_FAMILY=glm-v

# 关闭推理模式以加速执行 (推荐)
MIDSCENE_MODEL_REASONING_ENABLED=false
