# ================================
# API 配置
# ================================
# 后端 API 地址 (默认: http://localhost:3000)
VITE_API_BASE_URL=http://localhost:3000

# API 超时时间 (毫秒，默认: 30000)
VITE_API_TIMEOUT=30000

# 启用 API 请求重试 (默认: true)
VITE_API_ENABLE_RETRY=true

# 最大重试次数 (默认: 3)
VITE_API_MAX_RETRIES=3

# ================================
# WebSocket 配置
# ================================
# WebSocket 服务器地址 (默认: ws://localhost:3001)
VITE_WS_URL=ws://localhost:3001

# 自动连接 WebSocket (默认: true)
VITE_WS_AUTO_CONNECT=true

# 重连间隔 (毫秒，默认: 3000)
VITE_WS_RECONNECT_INTERVAL=3000

# 最大重连尝试次数 (默认: 5)
VITE_WS_MAX_RECONNECT=5

# ================================
# 应用配置
# ================================
# 应用名称 (默认: Auto Test Agent)
VITE_APP_NAME=Auto Test Agent

# 应用版本 (默认: 0.1.0)
VITE_APP_VERSION=0.1.0

# 应用标题 (默认: 自动化测试控制台)
VITE_APP_TITLE=自动化测试控制台

# 应用描述 (默认: 智能化自动化测试平台)
VITE_APP_DESCRIPTION=智能化自动化测试平台

# ================================
# UI 配置
# ================================
# 界面主题: light, dark, auto (默认: light)
VITE_UI_THEME=light

# 界面语言 (默认: zh-CN)
VITE_UI_LANGUAGE=zh-CN

# 时区设置 (默认: Asia/Shanghai)
VITE_UI_TIMEZONE=Asia/Shanghai

# 启用动画效果 (默认: true)
VITE_UI_ENABLE_ANIMATIONS=true

# ================================
# 功能开关
# ================================
# 启用 WebSocket 功能 (默认: true)
VITE_FEATURE_WEBSOCKET=true

# 启用 Mock 数据 (默认: true)
VITE_FEATURE_MOCK=true

# 启用日志功能 (默认: true)
VITE_FEATURE_LOGS=true

# 启用截图功能 (默认: true)
VITE_FEATURE_SCREENSHOTS=true

# 启用报告功能 (默认: true)
VITE_FEATURE_REPORTS=true

# ================================
# 开发配置
# ================================
# 启用调试模式 (默认: false，开发环境自动启用)
VITE_DEV_DEBUG=false

# 启用 Mock 测试数据 (默认: false)
VITE_DEV_MOCK_DATA=false

# 日志级别: debug, info, warn, error (默认: info)
VITE_DEV_LOG_LEVEL=info
