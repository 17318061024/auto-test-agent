# ================================
# 服务器配置
# ================================
# 服务器主机名 (默认: localhost)
SERVER_HOST=localhost

# HTTP 服务器端口 (默认: 3000)
PORT=3000

# WebSocket 服务器端口 (默认: 3001)
WS_PORT=3001

# 运行环境: development, production, test (默认: development)
NODE_ENV=development

# 启用 HTTPS (默认: false)
HTTPS=false

# 启用 WSS (WebSocket Secure) (默认: false)
WSS=false

# ================================
# CORS 配置
# ================================
# 允许的来源，逗号分隔 (默认: http://localhost:5173,http://localhost:3000)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ================================
# 路径配置
# ================================
# 数据目录 (默认: ./data)
DATA_DIR=./data

# 日志目录 (默认: ./logs)
LOGS_DIR=./logs

# 临时文件目录 (默认: ./temp)
TEMP_DIR=./temp

# 截图保存目录 (默认: ./data/screenshots)
SCREENSHOTS_DIR=./data/screenshots

# 报告保存目录 (默认: ./data/reports)
REPORTS_DIR=./data/reports

# 任务数据目录 (默认: ./data/tasks)
TASKS_DIR=./data/tasks

# ================================
# 数据库配置
# ================================
# SQLite 数据库文件路径 (默认: ./data/tasks.db)
DATABASE_URL=./data/tasks.db

# 数据库连接池大小 (默认: 10)
DATABASE_POOL_SIZE=10

# ================================
# 日志配置
# ================================
# 日志级别: debug, info, warn, error (默认: info)
LOG_LEVEL=info

# 日志文件路径 (默认: ./logs/server.log)
LOG_FILE=./logs/server.log

# 日志文件最大大小 (字节，默认: 10485760 = 10MB)
LOG_MAX_SIZE=10485760

# 日志文件最大数量 (默认: 5)
LOG_MAX_FILES=5

# ================================
# 任务执行配置
# ================================
# 任务超时时间 (毫秒，默认: 30000 = 30秒)
TASK_TIMEOUT=30000

# 最大重试次数 (默认: 3)
MAX_RETRIES=3

# 默认无头模式 (默认: false)
DEFAULT_HEADLESS=false

# 失败时截图 (默认: true)
SCREENSHOT_ON_FAILURE=true

# 慢速模式延迟 (毫秒，默认: 0)
SLOW_MO=0

# ================================
# Playwright 配置
# ================================
# 浏览器路径 (0 = 使用系统安装的浏览器)
PLAYWRIGHT_BROWSERS_PATH=0

# 浏览器通道: chromium, firefox, webkit (默认: chromium)
PLAYWRIGHT_CHANNEL=chromium

# 启用开发者工具 (默认: false)
PLAYWRIGHT_DEVTOOLS=false

# ================================
# 客户端配置
# ================================
# 心跳间隔 (毫秒，默认: 30000 = 30秒)
CLIENT_HEARTBEAT_INTERVAL=30000

# 客户端超时时间 (毫秒，默认: 60000 = 60秒)
CLIENT_TIMEOUT=60000

# 最大重连尝试次数 (默认: 5)
CLIENT_MAX_RECONNECT=5

# ================================
# API 配置
# ================================
# 速率限制窗口 (毫秒，默认: 900000 = 15分钟)
RATE_LIMIT_WINDOW=900000

# 速率限制最大请求数 (默认: 100)
RATE_LIMIT_MAX=100

# ================================
# 性能配置
# ================================
# 启用性能分析 (默认: false)
ENABLE_PROFILING=false

# 启用性能指标 (默认: true)
ENABLE_METRICS=true

# ================================
# 调试配置
# ================================
# 启用调试模式 (默认: false)
DEBUG=false
