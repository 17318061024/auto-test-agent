# Auto Test Agent - 环境配置文件
# 复制此文件为 .env 并根据需要修改配置

# ===========================================
# 🖥️ 服务器配置
# ===========================================
SERVER_HOST=localhost
SERVER_PORT=3000
WS_PORT=3001
API_BASE_PATH=/api
SERVER_TIMEOUT=30000

# ===========================================
# 👥 客户端配置
# ===========================================
CLIENT_NAME=auto-test-agent
RECONNECT_INTERVAL=3000
MAX_RECONNECT_ATTEMPTS=5
HEARTBEAT_INTERVAL=30000

# ===========================================
# ⚙️ 任务执行配置
# ===========================================
MAX_RETRIES=3
RETRY_DELAY=2000
STEP_TIMEOUT=30000
HEADLESS=true
PERFORMANCE_THRESHOLD=10000
AUTO_OPTIMIZATION=true
PERFORMANCE_MONITORING=true

# ===========================================
# 🌐 Chrome 浏览器配置
# ===========================================
PREFER_SYSTEM_CHROME=true
CHROME_PATH=
CHROME_DEBUG_PORT=9222

# ===========================================
# 📊 日志系统配置
# ===========================================
LOG_LEVEL=info
ENABLE_FILE_LOGGING=true
LOG_FILE_PATH=./logs
MAX_LOG_FILE_SIZE=10
LOG_RETENTION_DAYS=7

# ===========================================
# 🎨 界面配置
# ===========================================
ENABLE_FULLSCREEN_LOGS=true
ENABLE_ERROR_ASSISTANT=true
LOG_REFRESH_INTERVAL=1000

# ===========================================
# 📁 数据存储路径配置
# ===========================================
DATA_DIR=./data
LOGS_DIR=./logs
TEMP_DIR=./temp
SCREENSHOTS_DIR=./data/screenshots
REPORTS_DIR=./data/reports
TASKS_DIR=./data/tasks

# ===========================================
# 🌐 网络与安全配置
# ===========================================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# ===========================================
# 🔐 HTTPS/WSS 配置
# ===========================================
HTTPS=false
WSS=false

# ===========================================
# 🎯 环境设置
# ===========================================
NODE_ENV=development
DEBUG=false

# ===========================================
# 📈 性能配置
# ===========================================
ENABLE_PROFILING=false
ENABLE_METRICS=true

# ===========================================
# 🎭 Playwright 配置
# ===========================================
PLAYWRIGHT_BROWSERS_PATH=0
PLAYWRIGHT_CHANNEL=chromium
PLAYWRIGHT_DEVTOOLS=false