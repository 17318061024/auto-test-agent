{
  "extends": "./config/tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "composite": true
  },
  "include": [
    "packages/*/src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules/**",
    "**/dist/**",
    "**/*.d.ts",
    "tests/**"
  ],
  "references": [
    { "path": "./packages/shared" },
    { "path": "./packages/task-executor" },
    { "path": "./packages/server" },
    { "path": "./packages/desktop-client" },
    { "path": "./packages/web-console" },
    { "path": "./packages/cli" }
  ]
}
